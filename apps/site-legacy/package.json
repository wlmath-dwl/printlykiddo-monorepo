{
  "name": "printlykiddo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' next dev",
    "build": "next build",
    "start": "next start",
    "db:pull": "node --disable-warning=ExperimentalWarning scripts/pull-local-db.mjs",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "node -e \"console.error('Disabled in local migration workspace'); process.exit(1)\"",
    "upload": "node -e \"console.error('Disabled in local migration workspace'); process.exit(1)\"",
    "dev:cf": "npm run preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv --include-runtime=false cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "jspdf": "^4.2.1",
    "next": "^15.5.10",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.75.0"
  }
}
