# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.open-next
.wrangler

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# SQLite runtime files (WAL/SHM) — 不要提交，运行时自动生成
*.sqlite-wal
*.sqlite-shm
*.db-wal
*.db-shm

# SQLite 历史备份 — 不纳入版本管理
data/local-admin.before-*.sqlite

# Local Pinterest OAuth review token — 不要提交真实授权 token
data/pinterest-review-token.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
