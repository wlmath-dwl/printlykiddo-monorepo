{
  "name": "@printlykiddo/site-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --local --persist-to ../../.local/wrangler",
    "typegen": "wrangler types worker-configuration.d.ts --env staging --env-interface CloudflareEnv --include-runtime=false",
    "typecheck": "tsc --noEmit",
    "dry-run:staging": "wrangler versions upload --env staging --dry-run",
    "dry-run:production": "wrangler versions upload --env production --dry-run",
    "deploy": "node -e \"console.error('Disabled: use the guarded migration runbook'); process.exit(1)\""
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260716.1",
    "typescript": "5.9.3",
    "wrangler": "4.111.0"
  }
}
