{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "printlykiddo-static-local",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-17",
  "assets": {
    "directory": "../../.local/r2",
    "binding": "LOCAL_PAGES",
    "run_worker_first": true
  },
  "observability": {
    "enabled": false
  }
}
